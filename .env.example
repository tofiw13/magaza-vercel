# ===== Vercel Environment Variables =====
# Supabase
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # service_role (gizli, server)
SUPABASE_ANON_KEY=eyJ...                # anon/publishable (frontend auth ucun)

# Tetbiq + admin
APP_SECRET=                              # node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_PASSWORD=admin123

# Balans artirma -> Telegram bildirisi
TELEGRAM_BOT_TOKEN=                      # @BotFather-dan
TELEGRAM_CHAT_ID=                        # @userinfobot-dan (reqem)

# Musteriye gosterilen odenis melumati (kart/IBAN)
PAYMENT_INFO=Kapital Bank · 4169 XXXX XXXX XXXX · Ad Soyad

# Stripe artiq istifade olunmur (balans modeli) - bos saxla
STRIPE_SECRET_KEY=
